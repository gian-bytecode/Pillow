# .coveragerc to control coverage.py

[report]
# Regexes for lines to exclude from consideration
exclude_also =
    # Don't complain if non-runnable code isn't run
    if 0:
    if __name__ == .__main__.:
    # Don't complain about debug code
    if DEBUG:
    # Don't complain about compatibility code for missing optional dependencies
    except ImportError
    if TYPE_CHECKING:
    @abc.abstractmethod
    # Empty bodies in protocols or abstract methods
    ^\s*def [a-zA-Z0-9_]+\(.*\)(\s*->.*)?:\s*\.\.\.(\s*#.*)?$
    ^\s*\.\.\.(\s*#.*)?$
# Skip files that have zero executed lines (e.g. GPU files when no GPU is
# available and all GPU tests are skipped via pytest.importorskip).
# This avoids coverage 7.x raising a hard "no-source" error in that case.
# Coverage is still measured normally when a GPU is present.
skip_empty = True

[run]
omit =
    checks/*.py
    Tests/createfontdatachunk.py
